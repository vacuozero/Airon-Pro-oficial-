<!DOCTYPE html>
<html>
<head>
  <title>Painel CEO TUBARÃO</title>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
</head>
<body style="font-family:Arial; padding:20px; max-width:800px; margin:auto">
  <h1>🔥 Painel CEO TUBARÃO</h1>
  <div id="login"></div>
  <div id="painel" style="display:none"></div>

  <script>
    // COLA TUA URL E KEY DO SUPABASE AQUI
    const SUPABASE_URL = 'https://https://nrchvbixnjtskiaupjvx.supabase.co"
    const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5yY2h2Yml4bmp0c2tpYXVwanZ4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI0OTI3NTYsImV4cCI6MjA5ODA2ODc1Nn0.T75rKSpVsNAsQxwSn5TsoZbgV8VbRqp-PM0zP9XaqMs"
    const supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY)

    async function init() {
      const { data: { user } } = await supabase.auth.getUser()
      
      // TRAVA: só teu email entra
      if (user?.email !== 'Melothalytad@gmail.com') {
        document.getElementById('login').innerHTML = '<h2>🚫 ACESSO NEGADO</h2>'
        return
      }

      carregarClientes()
    }

    async function carregarClientes() {
      const { data } = await supabase.from('licenca_auron').select('*').order('created_at', {ascending:false})
      let html = '<h2>Clientes</h2><table border=1 width=100%><tr><th>Email</th><th>Status</th><th>Ação</th></tr>'
      data.forEach(c => {
        html += `<tr>
          <td>${c.email}</td>
          <td>${c.ativo ? '✅ ATIVO' : '❌ INATIVO'}</td>
          <td><button onclick="toggle('${c.email}', ${c.ativo})">${c.ativo ? 'DESATIVAR' : 'ATIVAR'}</button></td>
        </tr>`
      })
      html += '</table>'
      document.getElementById('painel').innerHTML = html
      document.getElementById('painel').style.display = 'block'
    }

    async function toggle(email, status) {
      await supabase.from('licenca_auron').update({ativo:!status}).eq('email', email)
      alert('Atualizado!')
      carregarClientes()
    }

    init()
  </script>
</body>
</html>
